# wayneblacktea — example environment file. Copy to .env, fill in real values.
# NEVER commit .env (already in .gitignore).

# --- Required ---
DATABASE_URL=postgres://USER:PASS@HOST:PORT/DB?sslmode=require
# Set to true when using Aiven / Railway Postgres (custom CA not in system trust store).
POSTGRES_INSECURE_TLS=true
API_KEY=replace-with-a-long-random-string

# --- Storage ---
# postgres (default) or sqlite.
STORAGE_BACKEND=postgres
# SQLITE_PATH=~/.wayneblacktea/data.db

# --- Workspace scoping (Phase B2) ---
# Leave unset for legacy single-user mode (no filter, NULL inserts).
# Set to a UUID after running migrations/000011_backfill_workspace_id.up.sql
# to enforce strict per-workspace reads and writes.
# WORKSPACE_ID=00000000-0000-0000-0000-000000000000
# USER_ID=wayne

# --- HTTP ---
PORT=8080
# MUST be explicit origins — wildcard "*" panics at startup (incompatible with cookie auth).
# Local dev example: http://localhost:5173
# Production example: https://your-app.up.railway.app
ALLOWED_ORIGINS=http://localhost:5173

# --- Optional integrations ---
# GEMINI_API_KEY=...           # vector search + dedup; falls back to URL-only dedup if unset
# DISCORD_BOT_TOKEN=...         # Discord bot session token; bot disabled if unset
# DISCORD_GUILD_ID=...          # Discord guild for slash command registration
# DISCORD_WEBHOOK_URL=...       # Outbound webhook for scheduled posts
# NOTION_INTEGRATION_SECRET=... # sync_to_notion target; tool errors if unset
# NOTION_DATABASE_ID=...        # Notion database for synced pages

# --- Optional LLM provider chain (Phases 1-4 of docs/openrouter-fallback.md) ---
# Memory-only mode is the default: leave everything below unset and the
# server still runs MCP tools, GTD, learning reviews, etc.
#
# Pick ONE selection mode (or none):
#   AI_PROVIDER=<name>                       — single primary provider
#   AI_FALLBACK_PROVIDERS=<a>,<b>,<c>        — ordered fallback chain
# Valid <name> values: claude, openrouter, groq.
# When neither is set, the chain auto-resolves to whichever provider keys
# are present (legacy backward-compat: Claude has priority).
# AI_PROVIDER=
# AI_FALLBACK_PROVIDERS=

# --- Provider-specific keys ---
# CLAUDE_API_KEY=...            # Anthropic Claude (classifier / reflection / snapshots)
# GROQ_API_KEY=...              # Groq (Discord /analyze legacy default)
# OPENROUTER_API_KEY=...        # OpenRouter (recommended for low-cost JSON tasks)
# OPENROUTER_MODEL=openrouter/free      # single-model default; safest zero-cost
# OPENROUTER_MODELS=                    # comma list passed as OpenRouter's `models`
#                                       # array (server-side routing: 1 HTTP call,
#                                       # 1 billing event). Use this for *availability
#                                       # / per-model rate limit / latency* failover —
#                                       # NOT to multiply the daily free quota.
#                                       # See docs/openrouter-fallback.md for current
#                                       # recommended free-model chain (rotates as
#                                       # OpenRouter retires models).
