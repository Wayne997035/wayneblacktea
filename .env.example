# wayneblacktea — example environment file. Copy to .env, fill in real values.
# NEVER commit .env (already in .gitignore).

# --- Required ---
DATABASE_URL=postgres://USER:PASS@HOST:PORT/DB?sslmode=require
API_KEY=replace-with-a-long-random-string

# --- Storage ---
# postgres (default) or sqlite (not yet implemented; will error at startup).
STORAGE_BACKEND=postgres

# --- Workspace scoping (Phase B2) ---
# Leave unset for legacy single-user mode (no filter, NULL inserts).
# Set to a UUID after running migrations/000011_backfill_workspace_id.up.sql
# to enforce strict per-workspace reads and writes.
# WORKSPACE_ID=00000000-0000-0000-0000-000000000000
# USER_ID=wayne

# --- HTTP ---
PORT=8080
ALLOWED_ORIGINS=*

# --- Optional integrations ---
# GEMINI_API_KEY=...           # vector search + dedup; falls back to URL-only dedup if unset
# GROQ_API_KEY=...              # Discord bot LLM analyzer
# DISCORD_BOT_TOKEN=...         # Discord bot session token; bot disabled if unset
# DISCORD_GUILD_ID=...          # Discord guild for slash command registration
# DISCORD_WEBHOOK_URL=...       # Outbound webhook for scheduled posts
# NOTION_INTEGRATION_SECRET=... # sync_to_notion target; tool errors if unset
# NOTION_DATABASE_ID=...        # Notion database for synced pages
